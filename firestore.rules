rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasRole(role) {
      return signedIn() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('superAdmin');
    }

    function isSuperAdmin() {
      return hasRole('superAdmin');
    }

    function reportKeys() {
      return [
        'id',
        'reporterId',
        'reporterDisplayName',
        'anonymous',
        'categoryId',
        'categoryLabel',
        'urgency',
        'description',
        'status',
        'syncStatus',
        'location',
        'media',
        'spamFlagged',
        'createdAt',
        'updatedAt',
        'submittedAt',
        'assignedTo',
        'adminNotesCount'
      ];
    }

    function isValidCitizenReportCreate(reportId) {
      return signedIn()
        && request.resource.data.keys().hasOnly(reportKeys())
        && request.resource.data.id == reportId
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.anonymous is bool
        && request.resource.data.categoryId is string
        && request.resource.data.categoryLabel is string
        && request.resource.data.urgency in ['normal', 'urgent', 'critical']
        && request.resource.data.description is string
        && request.resource.data.status in ['pendingUpload', 'uploading', 'submitted', 'failed']
        && request.resource.data.syncStatus in ['pendingUpload', 'uploading', 'submitted', 'failed']
        && request.resource.data.spamFlagged == false
        && request.resource.data.assignedTo == null
        && request.resource.data.adminNotesCount == 0;
    }

    function isReportOwner() {
      return signedIn() && resource.data.reporterId == request.auth.uid;
    }

    function keepsReportOwnership() {
      return request.resource.data.id == resource.data.id
        && request.resource.data.reporterId == resource.data.reporterId
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function citizenReportUpdateFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['syncStatus', 'media', 'updatedAt']);
    }

    function adminReportUpdateFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'status',
          'assignedTo',
          'spamFlagged',
          'adminNotesCount',
          'updatedAt'
        ]);
    }

    function isValidMediaCreate(mediaId) {
      return signedIn()
        && request.resource.data.id == mediaId
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.reportId is string
        && request.resource.data.type in ['image', 'video', 'voice']
        && request.resource.data.storagePath is string
        && request.resource.data.contentType is string
        && request.resource.data.sizeBytes is number
        && request.resource.data.status in ['pending', 'uploaded'];
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role == 'user';
      allow read: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.role == resource.data.role)
        || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /reports/{reportId} {
      allow create: if isValidCitizenReportCreate(reportId);
      allow read: if isReportOwner() || isAdmin();
      allow update: if (isReportOwner()
          && keepsReportOwnership()
          && citizenReportUpdateFieldsOnly())
        || (isAdmin()
          && keepsReportOwnership()
          && adminReportUpdateFieldsOnly());
      allow delete: if isSuperAdmin();
    }

    match /report_media/{mediaId} {
      allow create: if isValidMediaCreate(mediaId);
      allow read: if (signedIn() && resource.data.ownerId == request.auth.uid)
        || isAdmin();
      allow update: if ((signedIn() && resource.data.ownerId == request.auth.uid)
          || isAdmin())
        && request.resource.data.id == resource.data.id
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.reportId == resource.data.reportId;
      allow delete: if isSuperAdmin();
    }

    match /report_categories/{categoryId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /admin_logs/{logId} {
      allow create: if isAdmin()
        && request.resource.data.adminId == request.auth.uid
        && request.resource.data.action is string
        && request.resource.data.createdAt is timestamp;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /app_settings/{settingId} {
      allow read: if signedIn();
      allow write: if isSuperAdmin();
    }

    match /rate_limits/{limitId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
