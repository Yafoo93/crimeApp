rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return signedIn() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('superAdmin');
    }

    function isSuperAdmin() {
      return hasRole('superAdmin');
    }

    function isAllowedEvidenceType() {
      return request.resource != null
        && request.resource.size <= 25 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
          || request.resource.contentType.matches('audio/.*')
        );
    }

    match /evidence/{ownerId}/{reportId}/{fileName} {
      allow read: if (signedIn() && request.auth.uid == ownerId) || isAdmin();
      allow create, update: if signedIn()
        && request.auth.uid == ownerId
        && isAllowedEvidenceType();
      allow delete: if (signedIn() && request.auth.uid == ownerId) || isSuperAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
